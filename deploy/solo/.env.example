# ClawFirm Solo .env
#
# `clawfirm init --tier solo` generates this file with secure random values.
# Do not commit the resulting .env. See .gitignore.

# ----- Versions (pinned by clawfirm CLI) -----
CLAWFIRM_VERSION=0.1.0
CLAWRAILS_VERSION=0.1.0
CLAWSECURE_VERSION=0.1.0

# ----- Generated secrets (init writes random values) -----
POSTGRES_PASSWORD=replace-me-with-32-byte-random
AUTHENTIK_SECRET_KEY=replace-me-with-50-byte-random
LANGFUSE_NEXTAUTH_SECRET=replace-me-with-32-byte-random
LANGFUSE_SALT=replace-me-with-32-byte-random
N8N_ENCRYPTION_KEY=replace-me-with-32-byte-random
N8N_JWT_SECRET=replace-me-with-32-byte-random
DIFY_SANDBOX_API_KEY=replace-me-with-32-byte-random

# ----- Optional: GPU + frontier APIs -----
# Leaving these empty keeps the system local-only.
HF_TOKEN=
VLLM_MODEL=Qwen/Qwen3.6-27B-Instruct
VLLM_TP=1

# Frontier API keys are NOT placed here. They live in OpenBao after
# `clawfirm secret set <provider> <key>`. Per-user policy in ClawSecure
# decides which sessions may use them.
